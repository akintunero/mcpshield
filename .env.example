# =============================================================================
# MCPShield environment configuration
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
# =============================================================================

# -----------------------------------------------------------------------------
# LocalStack / AWS (participants run LocalStack themselves; it is NOT started by
# docker compose). These credentials are dummy values accepted by LocalStack.
# -----------------------------------------------------------------------------
LOCALSTACK_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
# When running INSIDE docker compose, containers reach LocalStack on the host:
# LOCALSTACK_ENDPOINT=http://host.docker.internal:4566

# -----------------------------------------------------------------------------
# MCP server
# -----------------------------------------------------------------------------
# Transport used by the server: "stdio" (default, for local/dev) or "http".
MCP_TRANSPORT=http
# HTTP bind + advertised URL (used by the agent, api, dashboard clients).
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=7801
MCP_SERVER_URL=http://localhost:7801/mcp
# Where the approval store is persisted (JSON file).
MCPSHIELD_STATE_DIR=./.mcpshield-state

# -----------------------------------------------------------------------------
# API + Dashboard
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=7802
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=7803
API_BASE_URL=http://localhost:7802

# -----------------------------------------------------------------------------
# Slack (Socket Mode — no public URL required)
#   1. Create an app from manifest (docs/slack.md).
#   2. Bot token starts with xoxb-, App-level token starts with xapp-.
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret
# Optional: restrict the bot to a single channel id for the workshop.
SLACK_ALLOWED_CHANNEL=

# -----------------------------------------------------------------------------
# LLM provider abstraction
#   LLM_PROVIDER: nim (default) | ollama | gemini | openai-compatible
#
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  RECOMMENDED: NVIDIA NIM — it is the cheapest and fastest option for   ║
# ║  this workshop. Sign up free at https://build.nvidia.com/ and get      ║
# ║  $200 free credits. Set LLM_PROVIDER=nim (default).                   ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# -----------------------------------------------------------------------------
LLM_PROVIDER=nim
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# NVIDIA NIM (default — RECOMMENDED for workshop).
# Uses the OpenAI-compatible /v1 API at integrate.api.nvidia.com.
# Get a free API key at https://build.nvidia.com/
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_API_KEY=nvapi-your-key
NIM_MODEL=meta/llama-3.1-70b-instruct

# Ollama (fully local, free — backup option).
# Install: https://ollama.com/  then  ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Google Gemini (free tier — backup option).
# Get key at https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Generic OpenAI-compatible endpoint (for testing).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
NODE_ENV=development

# -----------------------------------------------------------------------------
# n8n (optional automation workflows)
# -----------------------------------------------------------------------------
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=mcpshield
