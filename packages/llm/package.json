{
  "name": "@mcpshield/llm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared LLM provider adapters for MCPShield (OpenAI-compatible, Ollama).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "start": "exit 0"
  },
  "dependencies": {
    "@mcpshield/types": "workspace:*",
    "@mcpshield/config": "workspace:*",
    "@mcpshield/logger": "workspace:*"
  }
}
