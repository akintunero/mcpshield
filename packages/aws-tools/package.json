{
  "name": "@mcpshield/aws-tools",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "start": "exit 0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/client-iam": "^3.726.0",
    "@aws-sdk/client-lambda": "^3.726.0",
    "@aws-sdk/client-sqs": "^3.726.0",
    "@aws-sdk/client-sns": "^3.726.0",
    "@aws-sdk/client-secrets-manager": "^3.726.0",
    "@aws-sdk/client-ssm": "^3.726.0",
    "@aws-sdk/client-dynamodb": "^3.726.0",
    "@aws-sdk/client-cloudwatch": "^3.726.0",
    "@aws-sdk/client-cloudtrail": "^3.726.0",
    "@aws-sdk/client-ec2": "^3.726.0",
    "@mcpshield/types": "workspace:*",
    "@mcpshield/shared": "workspace:*",
    "@mcpshield/logger": "workspace:*",
    "@mcpshield/config": "workspace:*"
  }
