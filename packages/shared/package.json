{
  "name": "@mcpshield/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cross-cutting utilities (ids, time, Result, retry) for MCPShield.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "start": "exit 0"
  }
}
