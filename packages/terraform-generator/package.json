{
  "name": "@mcpshield/terraform-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "start": "exit 0"
  },
  "dependencies": {
    "@mcpshield/types": "workspace:*",
    "@mcpshield/shared": "workspace:*",
    "@mcpshield/logger": "workspace:*",
    "@mcpshield/config": "workspace:*",
    "@mcpshield/finding-engine": "workspace:*"
  }
}
