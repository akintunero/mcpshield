{
  "name": "@mcpshield/config",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Zod-validated environment configuration loader for MCPShield.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "start": "exit 0"
  },
  "dependencies": {
    "@mcpshield/types": "workspace:*",
    "dotenv": "^16.4.7",
    "zod": "^3.25.0"
  }
}
